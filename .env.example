# Data Formatter Agent — local configuration

# disabled: no payment required (local dev, tests)
# x402: live x402 v2 payment verification (Base mainnet)
FORMATTER_PAYMENT_MODE=disabled

# Anthropic API key — required for all conversions
ANTHROPIC_API_KEY=sk-ant-...

# x402 payment settings (defaults are Base mainnet — only override for testing)
FORMATTER_X402_PAY_TO=0x8fC4006534801c17A3368075A1Fb3b3C511EdB1F
FORMATTER_X402_NETWORK=eip155:8453
FORMATTER_X402_ASSET=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
FORMATTER_X402_AMOUNT=5000
FORMATTER_X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
FORMATTER_X402_REAL_VERIFICATION_ENABLED=false

# Resource URL returned in 402 responses (update after Railway deploy)
FORMATTER_RESOURCE_URL=https://project-formatter-production.up.railway.app/v1/format

# Request logging
FORMATTER_LOG_REQUESTS=true
